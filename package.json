{
  "name": "skills-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "skillmgr": "bin/skillmgr.js"
  },
  "scripts": {
    "dev:be": "tsx watch src/index.ts",
    "dev:fe": "vite",
    "build:fe": "vite build",
    "build:be": "tsc -p tsconfig.be.json",
    "build": "npm run build:fe && npm run build:be",
    "start": "node bin/skillmgr.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/static": "^7.0.4",
    "env-paths": "^3.0.0",
    "fastify": "^4.28.0",
    "open": "^10.1.0",
    "simple-git": "^3.25.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^29.1.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.25.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
  }
}
